# OwnPilot Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_USER=ownpilot
POSTGRES_PASSWORD=ownpilot
POSTGRES_DB=ownpilot
POSTGRES_PORT=5432

# =============================================================================
# Admin Key (for database export/import/backup operations)
# =============================================================================
# Generate: openssl rand -hex 32
ADMIN_KEY=

# =============================================================================
# Application
# =============================================================================
GATEWAY_PORT=8080
WS_PORT=18789
JWT_SECRET=

# =============================================================================
# AI Provider API Keys (optional)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# =============================================================================
# MQTT
# =============================================================================
MQTT_PORT=1883
MQTT_WS_PORT=9001

# =============================================================================
# Optional: PGAdmin
# =============================================================================
PGADMIN_EMAIL=admin@ownpilot.local
PGADMIN_PASSWORD=
PGADMIN_PORT=5050
