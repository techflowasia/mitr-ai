{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "composite": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": "./node_modules/.cache/tsconfig-node",
    "declarationDir": "./node_modules/.cache/tsconfig-node",
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig-node/tsconfig.node.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
