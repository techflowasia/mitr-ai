# Dependencies
node_modules/
.pnpm-store/
# Build
dist/
*.tsbuildinfo
# Test
coverage/
# IDE
.idea/
.vscode/
*.swp
*.swo
# OS
.DS_Store
Thumbs.db
nul
# Env - NEVER commit real credentials!
.env
.env.local
.env.*.local
# Logs
*.log
npm-debug.log*
pnpm-debug.log*
# Turbo
.turbo/
# Vault & Credentials (never commit!)
*.vault.json
credentials.enc
*.key
*.pem
*.p12
# User Data - contains personal information
data/
.data/
!packages/core/data/
!packages/core/data/providers/
!packages/core/data/providers/*.json
!packages/gateway/data/
!packages/gateway/data/default-extensions/
!packages/gateway/data/default-extensions/*/
!packages/gateway/data/default-extensions/**/*.json
!packages/gateway/data/example-skills/
!packages/gateway/data/example-skills/*/
!packages/gateway/data/example-skills/**/*
!packages/ui/src/**/data/
!packages/ui/src/**/data/*.ts
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
# CLI session/config directories (auto-created by CLI tools)
.claude/settings.local.json
.gemini/
.codex/
# Misc
*.bak
*.tmp
# Generated dev artifacts
models-dev-full.json
.codemap/
.codemapignore
# Runtime workspace directories
packages/gateway/workspace/
# Old tool artifacts
.serena/
# Data analysis artifacts (not part of the codebase)
packages/gateway/*.py
packages/gateway/*.csv
packages/gateway/*.png
# Debug/cache
.cache/
*.cache
# Temp helper scripts (prefixed with _)
_*.js
_*.mjs
_*.cjs
_*.txt
_*.json
_*.b64
_*.py
# Stray tool/test directories that don't belong in the monorepo
**/playwright_test/
**/playwright-report/
**/test-results/
**/.playwright/
**/e2e-results/
# Prevent random package installs inside workspace packages
packages/*/package-lock.json
packages/**/package-lock.json
package-lock.json
# Allow website's package-lock.json (npm project, not pnpm)
!website/package-lock.json
# Stray Python/data files anywhere in packages
packages/**/*.py
packages/**/*.csv
packages/**/*.png
packages/**/*.b64
docs/MINIMAX_CHECK.md
docs/QWEN_CHECK.md
.playwright-mcp/
# Internal/private planning docs — never commit
.planning/
docs/screenshots/t4f-poc/
docs/T4F-POC-*.md
**/HANDOFF-*.md
**/SESSION_HANDOFF_*.md
**/POSTMORTEM-*.md
.dfmt/
# Security review output — generated, not source
security-report/
security-reports/
security-reports/*
