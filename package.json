{
  "name": "ownpilot-monorepo",
  "version": "0.7.2",
  "private": true,
  "description": "OwnPilot - Privacy-first personal AI assistant platform",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ownpilot/ownpilot.git"
  },
  "author": "OwnPilot",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage",
    "ci": "pnpm run release:verify",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "typecheck:ci": "turbo typecheck:ci",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "version:show": "node -e \"console.log(require('./package.json').version)\"",
    "version:set": "node scripts/bump-version.mjs",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "version:prerelease": "node scripts/bump-version.mjs prerelease",
    "release:check": "node scripts/release-check.mjs",
    "release:notes": "node scripts/release-notes.mjs",
    "release:dry-run": "pnpm run release:check && pnpm run release:notes",
    "release:verify": "pnpm run release:check && pnpm run audit:prod && pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test",
    "release:verify:strict": "pnpm run release:verify && pnpm run format:check",
    "release:prepare": "pnpm run version:minor && pnpm run release:check",
    "release:prepare:patch": "pnpm run version:patch && pnpm run release:check",
    "release:prepare:major": "pnpm run version:major && pnpm run release:check",
    "release:tag": "node scripts/release-tag.mjs",
    "release:publish": "git push origin HEAD --follow-tags",
    "db:up": "docker compose -f docker-compose.db.yml up -d --wait",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:reset": "docker compose -f docker-compose.db.yml down -v && docker compose -f docker-compose.db.yml up -d --wait",
    "db:logs": "docker compose -f docker-compose.db.yml logs -f postgres",
    "clean": "turbo clean && rimraf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "node-pty"
    ],
    "overrides": {
      "@isaacs/brace-expansion": ">=5.0.1",
      "esbuild": ">=0.25.0",
      "undici": ">=7.24.0",
      "minimatch": ">=10.2.3",
      "flatted": ">=3.4.0",
      "dompurify": "3.4.0",
      "file-type": ">=21.3.3",
      "express-rate-limit": ">=8.3.0",
      "lodash": ">=4.18.0",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "music-metadata": ">=11.12.3",
      "brace-expansion": ">=5.0.5",
      "nodemailer": ">=8.0.5",
      "protobufjs": "8.4.0",
      "fast-uri": "3.1.2",
      "basic-ftp": "6.0.1",
      "vite": "7.3.3",
      "hono": "4.12.21",
      "@hono/node-server": "1.19.13",
      "axios": "1.16.1",
      "ip-address": "10.1.1",
      "follow-redirects": "1.16.0",
      "postcss": "8.5.10",
      "qs": ">=6.15.2"
    },
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
